# ACMS Frontend Environment Variables

# The base URL of the backend API
# If deployed on a subfolder (e.g. apps.kedok.ac.id/acms), point this to the API subfolder
NEXT_PUBLIC_API_URL=https://apps.kedok.ac.id/acms-api

# If testing locally, it would be:
# NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Sentry (error monitoring) — DORMAN bila DSN kosong ---
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
