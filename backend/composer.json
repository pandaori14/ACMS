{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "barryvdh/laravel-dompdf": "^3.1",
        "endroid/qr-code": "^6.0",
        "laravel/framework": "^12.0",
        "laravel/pulse": "^1.7",
        "laravel/sanctum": "^4.3",
        "laravel/socialite": "^5.27",
        "laravel/tinker": "^2.10.1",
        "maatwebsite/excel": "^3.1",
        "nwidart/laravel-modules": "^12.0",
        "spatie/laravel-permission": "^6.25"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.24",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpunit/phpunit": "^11.5.50"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "Modules\\Auth\\": "Modules/Auth/app/",
            "Modules\\Academic\\": "Modules/Academic/app/",
            "Modules\\Academic\\Database\\Seeders\\": "Modules/Academic/database/seeders/",
            "Modules\\Rotation\\": "Modules/Rotation/app/",
            "Modules\\Rotation\\Database\\Seeders\\": "Modules/Rotation/database/seeders/",
            "Modules\\Clinical\\": "Modules/Clinical/app/",
            "Modules\\Clinical\\Database\\Seeders\\": "Modules/Clinical/database/seeders/",
            "Modules\\Assessment\\": "Modules/Assessment/app/",
            "Modules\\Assessment\\Database\\Seeders\\": "Modules/Assessment/database/seeders/",
            "Modules\\Examination\\": "Modules/Examination/app/",
            "Modules\\Examination\\Database\\Seeders\\": "Modules/Examination/database/seeders/",
            "Modules\\Finance\\": "Modules/Finance/app/",
            "Modules\\Finance\\Database\\Seeders\\": "Modules/Finance/database/seeders/",
            "Modules\\Core\\": "Modules/Core/app/",
            "Modules\\Attendance\\": "Modules/Attendance/app/",
            "Modules\\Attendance\\Database\\Seeders\\": "Modules/Attendance/database/seeders/",
            "Modules\\Evaluation\\": "Modules/Evaluation/app/",
            "Modules\\Evaluation\\Database\\Seeders\\": "Modules/Evaluation/database/seeders/",
            "Modules\\Incident\\": "Modules/Incident/app/",
            "Modules\\Incident\\Database\\Seeders\\": "Modules/Incident/database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "wikimedia/composer-merge-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
