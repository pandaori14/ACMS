# ============================================================
# ACMS — .env PRODUKSI (server kampus UMS). SALIN ke backend/.env di server,
# lalu isi nilai rahasia. JANGAN commit file .env ke git.
# ============================================================

APP_NAME="ACMS"
APP_ENV=production
APP_KEY=                      # isi dgn: php artisan key:generate
APP_DEBUG=false               # WAJIB false di produksi
APP_URL=https://domain.ums.ac.id/acms

# --- Akun Super Admin awal (dipakai ProductionSeeder; HAPUS/kosongkan setelah login pertama) ---
ADMIN_NAME="Administrator ACMS"
ADMIN_EMAIL=admin@ums.ac.id
ADMIN_PASSWORD=          # password kuat; JANGAN "password". Ganti via UI setelah login pertama.

# --- Database: MySQL HOST (di luar container) ---
# Isi DB_HOST dengan IP LAN server (lihat: hostname -I), mis. 172.16.10.5 atau 10.x.x.x.
# (Podman lama tak dukung host.containers.internal; pakai IP host langsung.)
DB_CONNECTION=mysql
DB_HOST=GANTI_IP_HOST
DB_PORT=3306
DB_DATABASE=acms_db
DB_USERNAME=acms
DB_PASSWORD=                  # password user MySQL khusus ACMS

# --- Sesi & Sanctum (SPA same-origin di subpath /acms) ---
SESSION_DRIVER=database
SESSION_DOMAIN=domain.ums.ac.id
SESSION_SECURE_COOKIE=true
SANCTUM_STATEFUL_DOMAINS=domain.ums.ac.id

# --- Cache & Queue (driver database; tanpa Redis) ---
CACHE_STORE=database
QUEUE_CONNECTION=database

# --- Logging ---
LOG_CHANNEL=stack
LOG_LEVEL=warning

# --- Mail (SMTP institusi) ---
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@ums.ac.id"
MAIL_FROM_NAME="${APP_NAME}"

# --- Google SSO (opsional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://domain.ums.ac.id/acms/api/sso/callback

# --- AI Assistant (opsional; bisa juga diatur via menu Settings) ---
AI_ENABLED=false
AI_BASE_URL=https://integrate.api.nvidia.com/v1
AI_MODEL=meta/llama-3.3-70b-instruct
AI_API_KEY=
AI_TIMEOUT=60
AI_MAX_TOKENS=4096

# --- Sentry (error monitoring) — DORMAN bila DSN kosong ---
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_SEND_DEFAULT_PII=false
